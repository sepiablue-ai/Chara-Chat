# Chara-Chat Environment Configuration

# GPU Assignments (0-indexed. If using a single GPU, set both to 0)
COMFYUI_GPU_ID=0
TTS_GPU_ID=0
OLLAMA_MODEL=gemma4:12b-it-qat

# Backend Service URLs and Ports
LLM_URL=http://127.0.0.1:11434/api/chat
COMFYUI_URL=http://127.0.0.1:8188
TTS_URL=http://127.0.0.1:7860
STREAMLIT_PORT=8501

# ComfyUI Output Directory (Absolute path)
# e.g., C:\comfyui\ComfyUI_windows_portable\ComfyUI\output
COMFYUI_OUTPUT_DIR=

# Irodori-TTS Checkpoint Path (Relative or Absolute)
# e.g., outputs\character_lora\checkpoint_final.safetensors
TTS_CHECKPOINT=
